   "source": [
    "# RAG de Multas v2 â€” Mejorado\n",
    "\n",
    "Mejoras sobre v1:\n",
    "1. **Modelo multilingÃ¼e** â†’ mejor para PDFs en espaÃ±ol\n",
    "2. **Cosine distance** â†’ mÃ©trica correcta para NLP\n",
    "3. **Hybrid search** â†’ dense (semÃ¡ntico) + sparse (BM25 keywords)\n",
    "4. **LLM conectado** â†’ pipeline completo con respuesta sintetizada\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Si te falta algo, descomenta y ejecuta:\n",
    "# !pip install pypdf sentence-transformers chromadb rank-bm25"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "from pypdf import PdfReader\n",
    "from sentence_transformers import SentenceTransformer\n",
    "import chromadb\n",
    "from rank_bm25 import BM25Okapi   # sparse search\n",
    "import json\n",`r`n    "import urllib.request\n",`r`n    "import urllib.error"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CONFIG\n",
    "DOCUMENTS_PATH = './documents'\n",
    "DB_PATH = './chromadb'\n",
    "COLLECTION_NAME = 'fotomultas'\n",
    "\n",
    "# FIX 1: modelo multilingÃ¼e â†’ entiende espaÃ±ol mucho mejor que all-MiniLM-L6-v2\n",
    "EMBEDDING_MODEL = os.getenv('EMBEDDING_MODEL', 'paraphrase-multilingual-MiniLM-L12-v2')\n",
    "\n",
    "CHUNK_SIZE = 500\n",
    "CHUNK_OVERLAP = 100\n",
    "\n",
    "# hybrid search: 1.0 = solo dense, 0.0 = solo sparse\n",
    "ALPHA = 0.7"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Igual que antes â€” sin cambios\n",
    "def chunk_text(text, chunk_size=CHUNK_SIZE, overlap=CHUNK_OVERLAP):\n",
    "    chunks = []\n",
    "    start = 0\n",
    "    while start < len(text):\n",
    "        end = start + chunk_size\n",
    "        chunk = text[start:end]\n",
    "        if chunk.strip():\n",
    "            chunks.append(chunk)\n",
    "        start += (chunk_size - overlap)\n",
    "    return chunks\n",
    "\n",
    "\n",
    "def read_pdf(pdf_path):\n",
    "    reader = PdfReader(pdf_path)\n",
    "    text = ''\n",
    "    for page in reader.pages:\n",
    "        extracted = page.extract_text() or ''\n",
    "        text += extracted + '\\n'\n",
    "    return text"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# FIX 2: cosine distance en vez de L2 (euclidean por defecto de ChromaDB)\n",
    "# En NLP cosine es la mÃ©trica correcta â€” mide Ã¡ngulo entre vectores, no distancia absoluta\n",
    "client = chromadb.PersistentClient(path=DB_PATH)\n",
    "collection = client.get_or_create_collection(\n",
    "    name=COLLECTION_NAME,\n",
    "    metadata={'hnsw:space': 'cosine'}   # â† fix clave\n",
    ")\n",
    "model = SentenceTransformer(EMBEDDING_MODEL)\n",
    "\n",
    "# BM25 se construye en memoria sobre los chunks cargados\n",
    "bm25_corpus = []   # lista de chunks en texto plano\n",
    "bm25_index = None  # se inicializa despuÃ©s de la ingesta\n",
    "\n",
    "print('Modelo:', EMBEDDING_MODEL)\n",
    "print('Coleccion:', COLLECTION_NAME)\n",
    "print('Distancia: cosine')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def ingest_documents(reset=False):\n",
    "    global collection, bm25_corpus, bm25_index\n",
    "\n",
    "    if reset:\n",
    "        try:\n",
    "            client.delete_collection(COLLECTION_NAME)\n",
    "        except Exception:\n",
    "            pass\n",
    "        collection = client.get_or_create_collection(\n",
    "            name=COLLECTION_NAME,\n",
    "            metadata={'hnsw:space': 'cosine'}  # mantener cosine al recrear\n",
    "        )\n",
    "        bm25_corpus = []\n",
    "\n",
    "    if not os.path.isdir(DOCUMENTS_PATH):\n",
    "        raise FileNotFoundError(f'No existe la carpeta: {DOCUMENTS_PATH}')\n",
    "\n",
    "    files = [f for f in os.listdir(DOCUMENTS_PATH) if f.lower().endswith('.pdf')]\n",
    "    if not files:\n",
    "        raise FileNotFoundError('No hay PDFs en ./documents')\n",
    "\n",
    "    total = 0\n",
    "    for file in files:\n",
    "        file_path = os.path.join(DOCUMENTS_PATH, file)\n",
    "        text = read_pdf(file_path)\n",
    "        chunks = chunk_text(text)\n",
    "\n",
    "        for idx, chunk in enumerate(chunks):\n",
    "            emb = model.encode(chunk).tolist()\n",
    "            chunk_id = f'{file}_{idx}'\n",
    "            collection.add(\n",
    "                documents=[chunk],\n",
    "                embeddings=[emb],\n",
    "                ids=[chunk_id],\n",
    "                metadatas=[{'source': file, 'chunk': idx}]\n",
    "            )\n",
    "            bm25_corpus.append(chunk)   # acumula para BM25\n",
    "            total += 1\n",
    "\n",
    "    # FIX 3: construir Ã­ndice BM25 con todos los chunks\n",
    "    tokenized = [c.lower().split() for c in bm25_corpus]\n",
    "    bm25_index = BM25Okapi(tokenized)\n",
    "\n",
    "    return {'pdfs': len(files), 'chunks': total}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ejecuta ingesta (usa reset=True si quieres reconstruir desde cero)\n",
    "result = ingest_documents(reset=False)\n",
    "result"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# FIX 3: Hybrid search â€” mezcla dense (semÃ¡ntico) + sparse (BM25 keywords)\n",
    "# alpha=1.0 â†’ solo dense | alpha=0.0 â†’ solo sparse | alpha=0.7 â†’ balance recomendado\n",
    "\n",
    "def hybrid_search(query, k=3, alpha=ALPHA):\n",
    "    # --- Dense search (igual que antes) ---\n",
    "    q_emb = model.encode(query).tolist()\n",
    "    dense_res = collection.query(\n",
    "        query_embeddings=[q_emb],\n",
    "        n_results=k * 2   # pedimos mÃ¡s para luego fusionar\n",
    "    )\n",
    "    dense_docs  = dense_res.get('documents',  [[]])[0]\n",
    "    dense_metas = dense_res.get('metadatas',  [[]])[0]\n",
    "    dense_dists = dense_res.get('distances',  [[]])[0]\n",
    "\n",
    "    # --- Sparse search (BM25) ---\n",
    "    tokenized_query = query.lower().split()\n",
    "    bm25_scores = bm25_index.get_scores(tokenized_query)  # score por cada chunk\n",
    "\n",
    "    # Normalizar BM25 scores a [0,1]\n",
    "    max_bm25 = max(bm25_scores) if max(bm25_scores) > 0 else 1\n",
    "    bm25_norm = [s / max_bm25 for s in bm25_scores]\n",
    "\n",
    "    # Top-k chunks por BM25\n",
    "    bm25_top_idx = sorted(range(len(bm25_norm)), key=lambda i: bm25_norm[i], reverse=True)[:k * 2]\n",
    "\n",
    "    # --- FusiÃ³n: Reciprocal Rank Fusion simplificada ---\n",
    "    scores = {}\n",
    "\n",
    "    # Score dense (convertir distancia cosine a similitud: 1 - dist)\n",
    "    for rank, (doc, meta, dist) in enumerate(zip(dense_docs, dense_metas, dense_dists)):\n",
    "        key = meta.get('source', '') + str(meta.get('chunk', ''))\n",
    "        dense_score = (1 - dist) * alpha\n",
    "        scores[key] = scores.get(key, {'doc': doc, 'meta': meta, 'score': 0})\n",
    "        scores[key]['score'] += dense_score\n",
    "\n",
    "    # Score sparse\n",
    "    for rank, idx in enumerate(bm25_top_idx):\n",
    "        chunk = bm25_corpus[idx]\n",
    "        # buscar metadata del chunk en collection (por posiciÃ³n)\n",
    "        sparse_score = bm25_norm[idx] * (1 - alpha)\n",
    "        # usamos el chunk como key si no estÃ¡ ya\n",
    "        key = f'bm25_{idx}'\n",
    "        if key not in scores:\n",
    "            scores[key] = {'doc': chunk, 'meta': {'source': 'bm25', 'chunk': idx}, 'score': 0}\n",
    "        scores[key]['score'] += sparse_score\n",
    "\n",
    "    # Ordenar por score final y tomar top-k\n",
    "    ranked = sorted(scores.values(), key=lambda x: x['score'], reverse=True)[:k]\n",
    "\n",
    "    out = []\n",
    "    for i, item in enumerate(ranked):\n",
    "        doc = item['doc']\n",
    "        out.append({\n",
    "            'rank': i + 1,\n",
    "            'source': item['meta'].get('source'),\n",
    "            'score': round(item['score'], 4),\n",
    "            'snippet': doc[:350] + ('...' if len(doc) > 350 else '')\n",
    "        })\n",
    "    return out"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# FIX 4: LLM conectado â€” pipeline completo\n",
    "# El contexto recuperado por hybrid_search se inyecta al prompt de Claude\n",
    "\n",
    "ANTHROPIC_API_KEY = os.getenv('ANTHROPIC_API_KEY', '')  # pon tu key aquÃ­ o en variable de entorno\n",
    "\n",
    "def ask_agent(query, k=3, alpha=ALPHA):\n",
    "    # Paso 1: recuperar contexto con hybrid search\n",
    "    chunks = hybrid_search(query, k=k, alpha=alpha)\n",
    "\n",
    "    if not chunks:\n",
    "        return {'error': 'No se encontrÃ³ contexto relevante en los documentos.'}\n",
    "\n",
    "    # Paso 2: construir contexto para el prompt\n",
    "    context_parts = []\n",
    "    for c in chunks:\n",
    "        context_parts.append(f\"[Fuente: {c['source']} | Score: {c['score']}]\\n{c['snippet']}\")\n",
    "    context = '\\n\\n---\\n\\n'.join(context_parts)\n",
    "\n",
    "    # Paso 3: prompt del agente de trÃ¡nsito\n",
    "    system_prompt = \"\"\"Eres un agente experto en multas de trÃ¡nsito en Colombia.\n",
    "Tu funciÃ³n es ayudar a los ciudadanos a entender sus fotomultas y el proceso de apelaciÃ³n.\n",
    "BasÃ¡ndote ÃšNICAMENTE en el contexto legal proporcionado, responde de forma clara y estructurada.\n",
    "Si el contexto no es suficiente para responder con certeza, indÃ­calo explÃ­citamente.\n",
    "Nunca inventes artÃ­culos, leyes o procedimientos que no estÃ©n en el contexto.\"\"\"\n",
    "\n",
    "    user_prompt = f\"\"\"CONTEXTO LEGAL RECUPERADO:\n",
    "{context}\n",
    "\n",
    "CONSULTA DEL CIUDADANO:\n",
    "{query}\n",
    "\n",
    "Por favor responde indicando:\n",
    "1. Â¿Se puede apelar esta multa? Â¿Por quÃ©?\n",
    "2. Â¿CÃ³mo es el proceso de apelaciÃ³n paso a paso?\n",
    "3. Â¿CuÃ¡l es la probabilidad estimada de Ã©xito? (Alta / Media / Baja) y por quÃ©.\n",
    "4. Â¿Hay algÃºn plazo o requisito crÃ­tico a tener en cuenta?\"\"\"\n",
    "\n",
    "    # Paso 4: llamar a Claude\n",
    "    llm = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n",
    "    message = llm.messages.create(\n",
    "        model='claude-opus-4-5',\n",
    "        max_tokens=1024,\n",
    "        system=system_prompt,\n",
    "        messages=[\n",
    "            {'role': 'user', 'content': user_prompt}\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    return {\n",
    "        'respuesta': message.content[0].text,\n",
    "        'chunks_usados': chunks   # Ãºtil para debug / trazabilidad\n",
    "    }"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prueba â€” hybrid search solo (sin LLM)\n",
    "hybrid_search('Como impugnar una fotomulta en Colombia?', k=3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prueba â€” pipeline completo con LLM\n",
    "respuesta = ask_agent('Me pusieron una fotomulta por exceso de velocidad, Â¿puedo apelarla?')\n",
    "print(respuesta['respuesta'])\n",
    "print('\\n--- Chunks usados ---')\n",
    "for c in respuesta['chunks_usados']:\n",
    "    print(f\"  [{c['rank']}] {c['source']} | score: {c['score']}\")"
   ]
  }
